# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_LOG_TOPIC=iot.raw.logs
KAFKA_PROCESSED_LOG_TOPIC=iot.processed.logs
KAFKA_CONSUMER_GROUP=iot-log-intelligence-local

# Local paths
LOCAL_RAW_DATA_PATH=./data/raw
LOCAL_PROCESSED_DATA_PATH=./data/processed
LOCAL_SAMPLE_DATA_PATH=./data/samples

# Local analytical storage
DUCKDB_PATH=./data/processed/iot_logs.duckdb

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_S3_BRONZE_BUCKET=
AWS_S3_SILVER_BUCKET=
AWS_S3_GOLD_BUCKET=

# Environment
PROJECT_ENV=local

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_TOPIC=iot_raw_logs
KAFKA_PROCESSED_TOPIC=iot_processed_logs
KAFKA_INVALID_TOPIC=iot_invalid_logs
KAFKA_ALERTS_TOPIC=iot_pipeline_alerts

# Local paths
HOST_PROJECT_ROOT=C:/path/to/IoT_Log_Intelligence_Pipeline
LOCAL_RAW_DATA_PATH=./data/raw
LOCAL_PROCESSED_DATA_PATH=./data/processed
LOCAL_SAMPLE_DATA_PATH=./data/samples
DATASET_PROFILE=sample
PRODUCER_INPUT_FILE=
PRODUCER_MAX_ROWS=0
PRODUCER_SEND_DELAY_MS=250
CONSUMER_GROUP_ID=iot-python-consumer
CONSUMER_MAX_MESSAGES=0
CONSUMER_IDLE_TIMEOUT_SECONDS=10

# Local analytical storage
DUCKDB_PATH=./data/processed/iot_logs.duckdb
DBT_PROFILES_DIR=/usr/app/dbt
POSTGRES_DB=iot_logs
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=iot_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
WAREHOUSE_LOADER_GROUP_ID=iot-warehouse-loader
WAREHOUSE_LOADER_MAX_MESSAGES=0
WAREHOUSE_LOADER_IDLE_TIMEOUT_SECONDS=10

# Optional Snowflake dbt target
SNOWFLAKE_ACCOUNT=your_snowflake_account
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=your_snowflake_role
SNOWFLAKE_DATABASE=your_snowflake_database
SNOWFLAKE_WAREHOUSE=your_snowflake_warehouse
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_THREADS=4

# Local object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=iot-data-lake
SPARK_FEATURES_LOCAL_PATH=data/processed/spark/device_features
SPARK_FEATURES_CONTAINER_PATH=/workspace/data/processed/spark/device_features
SPARK_FEATURES_OBJECT_PREFIX=spark/device_features/latest

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_S3_BRONZE_BUCKET=
AWS_S3_SILVER_BUCKET=
AWS_S3_GOLD_BUCKET=
